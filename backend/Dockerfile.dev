# RTF Reporting Tool - Backend Development Dockerfile
# Build context: repo root
FROM node:20-alpine

RUN apk add --no-cache \
    python3 \
    make \
    g++ \
    libxml2-dev \
    libxslt-dev \
    curl

WORKDIR /app

# Root package.json + lock für workspaces
COPY package.json package-lock.json* ./

# Workspace package.json files
COPY shared/package.json ./shared/
COPY backend/package.json ./backend/

# Alle dependencies inkl. shared installieren (workspace-aware)
RUN npm install --legacy-peer-deps

# Shared source kopieren und bauen
COPY shared/ ./shared/
RUN npm run build -w shared

# Backend source wird per Volume gemountet
WORKDIR /app/backend

EXPOSE 3001
HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
  CMD curl -f http://localhost:3001/api/v1/health || exit 1
CMD ["npm", "run", "dev"]