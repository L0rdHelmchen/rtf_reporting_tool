 # RTF Reporting Tool - Frontend Development Dockerfile
# Build context: repo root
FROM node:20-alpine

RUN apk add --no-cache \
    python3 \
    make \
    g++ \
    git \
    curl

WORKDIR /app

# Root package.json + lock für workspaces
COPY package.json package-lock.json* ./

# Workspace package.json files
COPY shared/package.json ./shared/
COPY frontend/package.json ./frontend/

# Alle dependencies inkl. shared installieren (workspace-aware)
RUN npm install --legacy-peer-deps

# Shared source kopieren und bauen
COPY shared/ ./shared/
RUN npm run build -w shared

# Frontend source wird per Volume gemountet
WORKDIR /app/frontend

EXPOSE 3000
HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD curl -f http://localhost:3000 || exit 1
CMD ["npm", "run", "dev"]