# RTF Reporting Tool - Environment Configuration

# Server Configuration
NODE_ENV=development
API_PORT=3001
API_HOST=0.0.0.0

# Database Configuration
DATABASE_URL=postgresql://rtf_user:rtf_password@localhost:5432/rtf_reporting
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_SESSION_PREFIX=rtf:session:

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# File Upload Configuration
UPLOAD_MAX_FILE_SIZE=52428800
UPLOAD_ALLOWED_TYPES=application/xml,text/xml,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# XBRL Configuration
XBRL_SCHEMA_BASE_PATH=../RTF_Validierungsdateien
XBRL_VALIDATE_ON_SUBMIT=true
XBRL_NAMESPACE_RTF=http://www.bundesbank.de/sprv/xbrl/fws/rtf/rtf-2023-12/2023-12-31

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_TIME_WINDOW=900000

# Email Configuration (for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_ADDRESS=noreply@rtf-tool.local

# Security
BCRYPT_ROUNDS=12
SESSION_SECURE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# Feature Flags
FEATURE_XBRL_VALIDATION=true
FEATURE_EMAIL_NOTIFICATIONS=false
FEATURE_AUDIT_LOGGING=true