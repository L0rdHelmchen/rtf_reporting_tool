# RTF Reporting Tool – Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=rtf_reporting
POSTGRES_USER=rtf_user
POSTGRES_PASSWORD=change_me_strong_password

# ── Backend ──────────────────────────────────────────────────────────────────
# PRODUCTION: Use rtf_app (non-superuser) so Row Level Security is enforced.
# DEVELOPMENT: rtf_user (superuser) is fine for convenience but bypasses RLS.
POSTGRES_APP_USER=rtf_app
POSTGRES_APP_PASSWORD=change_me_app_password

# DATABASE_URL used by the backend application
# Production: postgresql://rtf_app:...@postgres:5432/rtf_reporting
# Development: postgresql://rtf_user:...@postgres:5432/rtf_reporting
DATABASE_URL=postgresql://rtf_app:change_me_app_password@postgres:5432/rtf_reporting
REDIS_URL=redis://redis:6379
API_PORT=3001
NODE_ENV=development

# JWT: min. 32 random characters, generate e.g. with:
#   openssl rand -hex 32
JWT_SECRET=change_me_min_32_chars_random_secret

# Rate limiting
RATE_LIMIT_MAX_REQUESTS=1000
